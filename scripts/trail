#!/usr/bin/env bash
#
# trail — global CLI for starting the trail engine + admin locally.
#
# Commands:
#   trail start              launch engine (58021) + admin (58031)
#   trail stop               kill both
#   trail restart            stop + start
#   trail status             show running state
#   trail logs               tail both logs; -f to follow
#   trail url                print the admin URL
#   trail install-daemon     install OS-native auto-restart supervisor
#                            (launchd on macOS, systemd on Linux). After
#                            this, start/stop/restart route through the
#                            supervisor automatically — same UX, but
#                            crashes auto-restart and the processes
#                            survive Mac sleep/wake/logout.
#   trail uninstall-daemon   remove the supervisor; back to manual mode.
#
# Adaptive routing: when a supervisor is detected (via launchctl/systemctl
# probe), every start/stop/restart command transparently routes through
# it. When no supervisor is installed, the script falls back to the
# original nohup-based foreground spawning. The CLI surface is identical
# either way — Christian's request: "trail start fortsat virker, men den
# skal bare virke adaptivt".
#
# State lives under ~/.trail/ — PID files, log files, and a generated
# TRAIL_INGEST_TOKEN if none exists in <repo>/buddy/.env or <repo>/.env.
# All paths are absolute so `trail` works from any cwd.

set -euo pipefail

# ── Repo path ───────────────────────────────────────────────────────
# Resolve the real location of this script even when invoked via a
# symlink in /usr/local/bin or ~/.local/bin. `readlink -f` is missing
# on older macOS so we do the walk manually.
resolve_script() {
  local src="$1"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")" && pwd
}
SCRIPT_DIR="$(resolve_script "${BASH_SOURCE[0]}")"
REPO="$(cd "$SCRIPT_DIR/.." && pwd)"

# ── Defaults ────────────────────────────────────────────────────────
ENGINE_PORT="${TRAIL_PORT:-58021}"
ADMIN_PORT="${TRAIL_ADMIN_PORT:-58031}"
STATE_DIR="$HOME/.trail"
ENGINE_PID_FILE="$STATE_DIR/engine.pid"
ADMIN_PID_FILE="$STATE_DIR/admin.pid"
ENGINE_LOG="$STATE_DIR/engine.log"
ADMIN_LOG="$STATE_DIR/admin.log"
ENV_FILE="$STATE_DIR/.env"

mkdir -p "$STATE_DIR"

# ── Helpers ─────────────────────────────────────────────────────────
is_running() {
  local pidfile="$1"
  [[ -f "$pidfile" ]] || return 1
  local pid
  pid="$(cat "$pidfile" 2>/dev/null || echo "")"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

# Locate or mint a TRAIL_INGEST_TOKEN. Preference order:
#   1. TRAIL_INGEST_TOKEN already exported
#   2. buddy/.env (the adversarial reviewer writes the same token there)
#   3. ~/.trail/.env (persisted across restarts)
#   4. generate a fresh 64-hex token and persist to ~/.trail/.env
resolve_token() {
  if [[ -n "${TRAIL_INGEST_TOKEN:-}" ]]; then
    echo "$TRAIL_INGEST_TOKEN"
    return
  fi
  local buddy_env="$HOME/Apps/webhouse/buddy/.env"
  if [[ -f "$buddy_env" ]] && grep -q '^TRAIL_INGEST_TOKEN=' "$buddy_env"; then
    grep '^TRAIL_INGEST_TOKEN=' "$buddy_env" | head -n1 | cut -d= -f2-
    return
  fi
  if [[ -f "$ENV_FILE" ]] && grep -q '^TRAIL_INGEST_TOKEN=' "$ENV_FILE"; then
    grep '^TRAIL_INGEST_TOKEN=' "$ENV_FILE" | head -n1 | cut -d= -f2-
    return
  fi
  local token
  token="$(openssl rand -hex 32)"
  echo "TRAIL_INGEST_TOKEN=$token" >> "$ENV_FILE"
  echo "$token"
}

port_free() {
  ! lsof -iTCP:"$1" -sTCP:LISTEN -nP >/dev/null 2>&1
}

# ── Supervisor detection (launchd / systemd / none) ────────────────────
# Returns one of: launchd | systemd | none
detect_supervisor() {
  case "$(uname -s)" in
    Darwin)
      # Capture launchctl output in a variable first — chaining via
      # `cmd && cmd | grep` interacts oddly with `set -o pipefail` in
      # subshells (debugged 2026-04-25). The two-step shape is robust
      # across bash 3.2 (macOS default) and 5.x (Homebrew).
      if command -v launchctl >/dev/null 2>&1; then
        local lc_out
        lc_out="$(launchctl list 2>/dev/null || true)"
        if [[ "$lc_out" == *"dk.broberg.trail.engine"* ]]; then
          echo "launchd"
          return
        fi
      fi
      ;;
    Linux)
      if command -v systemctl >/dev/null 2>&1; then
        local sd_out
        sd_out="$(systemctl --user list-unit-files 2>/dev/null || true)"
        if [[ "$sd_out" == *"trail-engine.service"* ]]; then
          echo "systemd"
          return
        fi
      fi
      ;;
  esac
  echo "none"
}

detect_os() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux)  echo "linux" ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *) echo "unknown" ;;
  esac
}

# Probe both ports until they answer or the timeout expires. Used by the
# supervisor-routed start commands; manual mode has its own probe loop
# tied to the spawned PIDs.
_wait_until_up() {
  local engine_up=0 admin_up=0
  for _ in $(seq 1 30); do
    (( !engine_up )) && \
      [[ "$(curl -s -o /dev/null -w '%{http_code}' "http://127.0.0.1:$ENGINE_PORT/api/v1/knowledge-bases" 2>/dev/null || echo 000)" != "000" ]] && \
      engine_up=1 && echo "  ✓ engine  :$ENGINE_PORT"
    (( !admin_up )) && \
      [[ "$(curl -s -o /dev/null -w '%{http_code}' "http://127.0.0.1:$ADMIN_PORT/" 2>/dev/null || echo 000)" != "000" ]] && \
      admin_up=1 && echo "  ✓ admin   :$ADMIN_PORT"
    (( engine_up && admin_up )) && return 0
    sleep 0.5
  done
  return 1
}

# ── Commands ────────────────────────────────────────────────────────
cmd_start() {
  local supervisor
  supervisor="$(detect_supervisor)"

  case "$supervisor" in
    launchd)
      # launchd's KeepAlive=true means the services were already started
      # when the plist was loaded. `kickstart` is a no-op if running, or
      # a fresh start if for some reason they're down.
      local uid
      uid="$(id -u)"
      launchctl kickstart "gui/$uid/dk.broberg.trail.engine" 2>/dev/null || true
      launchctl kickstart "gui/$uid/dk.broberg.trail.admin"  2>/dev/null || true
      echo "trail: started via launchd (engine :$ENGINE_PORT, admin :$ADMIN_PORT)"
      _wait_until_up && echo "  open → http://127.0.0.1:$ADMIN_PORT"
      return
      ;;
    systemd)
      systemctl --user start trail-engine.service trail-admin.service
      echo "trail: started via systemd (engine :$ENGINE_PORT, admin :$ADMIN_PORT)"
      _wait_until_up && echo "  open → http://127.0.0.1:$ADMIN_PORT"
      return
      ;;
  esac

  if is_running "$ENGINE_PID_FILE" && is_running "$ADMIN_PID_FILE"; then
    echo "trail: already running (engine :$ENGINE_PORT, admin :$ADMIN_PORT)"
    exit 0
  fi

  if ! port_free "$ENGINE_PORT"; then
    echo "trail: port $ENGINE_PORT is busy — set TRAIL_PORT or free it" >&2
    exit 1
  fi
  if ! port_free "$ADMIN_PORT"; then
    echo "trail: port $ADMIN_PORT is busy — set TRAIL_ADMIN_PORT or free it" >&2
    exit 1
  fi

  local token
  token="$(resolve_token)"

  echo "trail: launching engine + admin…"
  # Source repo-root .env into the engine's process environment so
  # provider-keys (OPENAI_API_KEY for F47 Whisper, OPENROUTER_API_KEY
  # for F149/F25, ANTHROPIC_API_KEY when set, R2 backup creds for F153,
  # tenant_secrets master key) are visible to the bun process. Bun's
  # own auto-load looks at the cwd's .env which is apps/server/ — not
  # repo root — so we must export here explicitly.
  (
    cd "$REPO" && \
    if [[ -f .env ]]; then set -a; source .env; set +a; fi && \
    TRAIL_DEV_AUTH=1 \
    TRAIL_DATA_DIR="$REPO/data" \
    TRAIL_INGEST_TOKEN="$token" \
    TRAIL_INGEST_TENANT_SLUG="${TRAIL_INGEST_TENANT_SLUG:-christian}" \
    TRAIL_PROJECT_ROOT="$REPO" \
    PORT="$ENGINE_PORT" \
    APP_URL="http://127.0.0.1:$ADMIN_PORT" \
    nohup bun run --cwd apps/server src/index.ts >"$ENGINE_LOG" 2>&1 &
    echo $! > "$ENGINE_PID_FILE"
  )

  (
    cd "$REPO" && \
    API_URL="http://127.0.0.1:$ENGINE_PORT" \
    nohup bun run --cwd apps/admin vite --port "$ADMIN_PORT" --host 127.0.0.1 --strictPort >"$ADMIN_LOG" 2>&1 &
    echo $! > "$ADMIN_PID_FILE"
  )

  # Actively probe both HTTP endpoints. Engine responds 401 (auth required)
  # without a session cookie — that's still "up". Admin returns 200 for /.
  # 10s ceiling is generous for a cold Vite start on an M1 Mac.
  local engine_up=0 admin_up=0
  # Probe without -f — the engine returns 401 without a session cookie, which
  # -f would treat as failure. Any 2xx/4xx means "the HTTP server is up".
  for _ in $(seq 1 20); do
    if (( !engine_up )); then
      local code
      code="$(curl -s -o /dev/null -w '%{http_code}' "http://127.0.0.1:$ENGINE_PORT/api/v1/knowledge-bases" 2>/dev/null || echo '000')"
      if [[ "$code" != "000" ]]; then
        engine_up=1
        echo "  ✓ engine  :$ENGINE_PORT"
      fi
    fi
    if (( !admin_up )); then
      local admin_code
      admin_code="$(curl -s -o /dev/null -w '%{http_code}' "http://127.0.0.1:$ADMIN_PORT/" 2>/dev/null || echo '000')"
      if [[ "$admin_code" != "000" ]]; then
        admin_up=1
        echo "  ✓ admin   :$ADMIN_PORT"
      fi
    fi
    (( engine_up && admin_up )) && break
    # Bail early if a process died during startup (no point waiting out the clock).
    is_running "$ENGINE_PID_FILE" || break
    is_running "$ADMIN_PID_FILE" || break
    sleep 0.5
  done

  if (( engine_up && admin_up )); then
    echo
    echo "  open → http://127.0.0.1:$ADMIN_PORT"
    echo "  logs → trail logs -f"
  else
    (( engine_up )) || echo "  ✗ engine did not come up" >&2
    (( admin_up )) || echo "  ✗ admin did not come up" >&2
    echo >&2
    echo "see logs: trail logs" >&2
    exit 1
  fi
}

cmd_stop() {
  local supervisor
  supervisor="$(detect_supervisor)"

  case "$supervisor" in
    launchd)
      # `kill` (no -9) sends SIGTERM. KeepAlive=true would respawn —
      # that's intended for crashes. To stop FOR REAL while leaving the
      # plist installed, unload it. To stop ONCE (knowing supervisor
      # will restart), use kill. Convention: trail stop = "really stop"
      # → unload. trail restart = "kick" → kickstart -k.
      local uid
      uid="$(id -u)"
      launchctl bootout "gui/$uid/dk.broberg.trail.admin"  2>/dev/null || true
      launchctl bootout "gui/$uid/dk.broberg.trail.engine" 2>/dev/null || true
      echo "trail: stopped via launchd (use 'trail start' to bring back up)"
      return
      ;;
    systemd)
      systemctl --user stop trail-admin.service trail-engine.service
      echo "trail: stopped via systemd"
      return
      ;;
  esac

  local stopped=0
  for pidfile in "$ENGINE_PID_FILE" "$ADMIN_PID_FILE"; do
    if is_running "$pidfile"; then
      local pid
      pid="$(cat "$pidfile")"
      # Kill children first (vite-dev-server, bun internal workers) then the
      # parent wrapper. Plain `kill $pid` leaves the Vite listener running
      # because bun forks it as a child that doesn't die with the parent.
      pkill -P "$pid" 2>/dev/null || true
      kill "$pid" 2>/dev/null || true
      stopped=1
    fi
    rm -f "$pidfile"
  done
  # Belt-and-braces: if something is still bound to our ports after the
  # pidfile-driven kill, take it out by port. Covers zombies from earlier
  # unclean exits we never had a pidfile for.
  for port in "$ENGINE_PORT" "$ADMIN_PORT"; do
    local orphans
    orphans="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "$orphans" ]]; then
      echo "$orphans" | xargs -r kill 2>/dev/null || true
      stopped=1
    fi
  done
  if (( stopped )); then
    echo "trail: stopped"
  else
    echo "trail: not running"
  fi
}

cmd_status() {
  local supervisor
  supervisor="$(detect_supervisor)"

  case "$supervisor" in
    launchd)
      local uid
      uid="$(id -u)"
      local engine_pid admin_pid
      engine_pid="$(launchctl list 2>/dev/null | awk '/dk\.broberg\.trail\.engine$/{print $1}')"
      admin_pid="$(launchctl list 2>/dev/null | awk '/dk\.broberg\.trail\.admin$/{print $1}')"
      [[ -z "$engine_pid" || "$engine_pid" == "-" ]] && engine_pid="—"
      [[ -z "$admin_pid"  || "$admin_pid"  == "-" ]] && admin_pid="—"
      printf "supervisor: launchd (gui/%s)\n" "$uid"
      printf "engine :%-5s  pid %s\n" "$ENGINE_PORT" "$engine_pid"
      printf "admin  :%-5s  pid %s\n" "$ADMIN_PORT" "$admin_pid"
      return
      ;;
    systemd)
      printf "supervisor: systemd --user\n"
      systemctl --user is-active trail-engine.service >/dev/null 2>&1 \
        && printf "engine :%-5s  active\n"  "$ENGINE_PORT" \
        || printf "engine :%-5s  inactive\n" "$ENGINE_PORT"
      systemctl --user is-active trail-admin.service >/dev/null 2>&1 \
        && printf "admin  :%-5s  active\n"  "$ADMIN_PORT" \
        || printf "admin  :%-5s  inactive\n" "$ADMIN_PORT"
      return
      ;;
  esac

  local engine_state="stopped"
  local admin_state="stopped"
  is_running "$ENGINE_PID_FILE" && engine_state="running (pid $(cat "$ENGINE_PID_FILE"))"
  is_running "$ADMIN_PID_FILE" && admin_state="running (pid $(cat "$ADMIN_PID_FILE"))"
  printf "supervisor: none (manual nohup)\n"
  printf "engine :%-5s  %s\n" "$ENGINE_PORT" "$engine_state"
  printf "admin  :%-5s  %s\n" "$ADMIN_PORT" "$admin_state"
}

cmd_logs() {
  local follow=""
  [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]] && follow="-f"
  if [[ -n "$follow" ]]; then
    tail -f "$ENGINE_LOG" "$ADMIN_LOG"
  else
    tail -n 50 "$ENGINE_LOG" "$ADMIN_LOG"
  fi
}

cmd_url() {
  echo "http://127.0.0.1:$ADMIN_PORT"
}

cmd_restart() {
  local supervisor
  supervisor="$(detect_supervisor)"

  case "$supervisor" in
    launchd)
      # kickstart -k = stop the running process (KeepAlive respawns it).
      # Faster than bootout+bootstrap and survives plist updates only on
      # next install. For schema/route changes during dev: this is the
      # "I just edited a file" command.
      local uid
      uid="$(id -u)"
      echo "trail: restarting via launchd…"
      launchctl kickstart -k "gui/$uid/dk.broberg.trail.engine" || true
      launchctl kickstart -k "gui/$uid/dk.broberg.trail.admin"  || true
      _wait_until_up && echo "  open → http://127.0.0.1:$ADMIN_PORT"
      return
      ;;
    systemd)
      echo "trail: restarting via systemd…"
      systemctl --user restart trail-engine.service trail-admin.service
      _wait_until_up && echo "  open → http://127.0.0.1:$ADMIN_PORT"
      return
      ;;
  esac

  cmd_stop || true
  sleep 1
  cmd_start
}

cmd_install_daemon() {
  local os
  os="$(detect_os)"
  case "$os" in
    macos)
      echo "trail: detected macOS — installing launchd plist…"
      bash "$REPO/scripts/install-launchd.sh"
      ;;
    linux)
      echo "trail: detected Linux — installing user-mode systemd unit…"
      bash "$REPO/scripts/install-systemd.sh"
      ;;
    windows)
      cat <<EOF >&2
trail: Windows is not yet supported by trail install-daemon.

Recommended setup for Windows users:
  1. Run trail under WSL2 (Linux subsystem) — then 'trail install-daemon'
     uses the systemd path natively.
  2. Or run 'trail start' manually each session and use Task Scheduler
     to bring it up at login.

If you build a Windows-native supervisor (NSSM, services.msc), please
contribute the script back to infra/windows/. See infra/launchd/ and
infra/systemd/ for how the macOS + Linux variants are structured.
EOF
      exit 1
      ;;
    *)
      echo "trail: unknown OS — install a supervisor manually." >&2
      echo "  See infra/launchd/ (macOS) or infra/systemd/ (Linux) for templates." >&2
      exit 1
      ;;
  esac
}

cmd_uninstall_daemon() {
  local os
  os="$(detect_os)"
  case "$os" in
    macos)   bash "$REPO/scripts/uninstall-launchd.sh" ;;
    linux)   bash "$REPO/scripts/uninstall-systemd.sh" ;;
    *)       echo "trail: nothing to uninstall on this OS." >&2 ;;
  esac
}

# ── Dispatch ────────────────────────────────────────────────────────
case "${1:-help}" in
  start)             cmd_start ;;
  stop)              cmd_stop ;;
  restart)           cmd_restart ;;
  status)            cmd_status ;;
  logs)              shift; cmd_logs "$@" ;;
  url)               cmd_url ;;
  install-daemon)    cmd_install_daemon ;;
  uninstall-daemon)  cmd_uninstall_daemon ;;
  help|--help|-h)
    cat <<EOF
trail — knowledge infrastructure engine, local dev CLI

Usage: trail <command>

Commands:
  start              launch engine + admin (routes via supervisor if installed)
  stop               stop both
  restart            stop + start (or supervisor-kickstart if installed)
  status             show running state + supervisor mode
  logs [-f]          show recent logs (or follow with -f)
  url                print the admin URL
  install-daemon     install OS-native auto-restart supervisor:
                       macOS  → launchd (~/Library/LaunchAgents)
                       Linux  → systemd --user (~/.config/systemd/user)
                     After install, start/stop/restart route through the
                     supervisor automatically. Crashes auto-restart;
                     services survive sleep/wake/logout.
  uninstall-daemon   remove the supervisor; revert to manual nohup mode.

Ports: \$TRAIL_PORT (engine, default 58021), \$TRAIL_ADMIN_PORT (admin, default 58031)
State: ~/.trail/ (pids, logs, generated token)
Repo:  $REPO
EOF
    ;;
  *)
    echo "trail: unknown command '$1' — run 'trail help'" >&2
    exit 1
    ;;
esac
