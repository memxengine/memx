# Google OAuth (required for auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs
APP_URL=http://localhost:3020
API_URL=http://localhost:3021

# Server port
PORT=3021

# Data directory (SQLite DB + uploaded files)
MEMX_DATA_DIR=./data

# Chat/ingest model — leave empty for plan default
CHAT_MODEL=claude-haiku-4-5-20251001
INGEST_MODEL=claude-haiku-4-5-20251001

# Direct Anthropic API (optional — falls back to claude -p subprocess)
# ANTHROPIC_API_KEY=

# Production only: serve admin app from server
# MEMX_SERVE_ADMIN=1

# Storage backend (Phase 2): local | r2 | s3
STORAGE_BACKEND=local
