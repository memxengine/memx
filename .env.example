# Google OAuth (required for auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs
APP_URL=http://localhost:3030
API_URL=http://localhost:3031

# Server port
PORT=3031

# Data directory (SQLite DB + uploaded files)
MEMX_DATA_DIR=./data

# LLM models — per-operation. Sonnet for jobs that write/reason over
# content (ingest compiles new Neurons from Sources — needs solid
# synthesis). Haiku for jobs that classify/extract/translate (chat
# answering over pre-indexed chunks, auto-link-sources inference,
# translation, contradiction-lint). Override per-op via the dedicated
# env vars when experimenting. Leave empty to use the CLI default.
CHAT_MODEL=claude-haiku-4-5-20251001
INGEST_MODEL=claude-sonnet-4-6
# TRAIL_TRANSLATE_MODEL=claude-haiku-4-5-20251001  # default
# TRAIL_AUTOLINK_MODEL=claude-haiku-4-5-20251001   # default
# TRAIL_CONTRADICTION_MODEL=claude-haiku-4-5-20251001  # default

# Direct Anthropic API (optional — falls back to claude -p subprocess)
# ANTHROPIC_API_KEY=

# Production only: serve admin app from server
# MEMX_SERVE_ADMIN=1

# Storage backend (Phase 2): local | r2 | s3
STORAGE_BACKEND=local

# ── F153: Continuous DB backup to Cloudflare R2 ─────────────────────
# Scheduled gzipped VACUUM-INTO snapshots of data/trail.db uploaded to a
# private R2 bucket. Feature is inert when any TRAIL_BACKUP_R2_* key is
# empty — the scheduler logs "disabled" and returns a no-op stop handle.
# See docs/features/F153-continuous-db-backup-to-r2.md for provisioning
# (bucket creation, token scope) + restore runbook.

# Cadence (0 disables the scheduler entirely)
TRAIL_BACKUP_INTERVAL_HOURS=6
TRAIL_BACKUP_RETAIN_DAYS=30
TRAIL_BACKUP_LOCAL_KEEP=3

# R2 destination (endpoint is per-Cloudflare-account)
TRAIL_BACKUP_R2_BUCKET=trail-backups
TRAIL_BACKUP_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
TRAIL_BACKUP_R2_ACCESS_KEY_ID=
TRAIL_BACKUP_R2_SECRET_ACCESS_KEY=
TRAIL_BACKUP_R2_PREFIX=trail-db/

# @webhouse/cms admin deploy token — per-site scoped to site:trail (F134).
# Grants deploy:trigger + deploy:read on this site only. Used by the
# onboarding app's "Finish setup" flow and by CI to fire landing rebuilds.
# Minted via CMS admin → Account → Access Tokens. See docs/F135 (pending).
CMS_ADMIN_URL=https://localhost:3010
CMS_DEPLOY_TOKEN=
